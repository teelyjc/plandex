generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model Board {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String
  columnOrder String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String
  boards      Board[]
  todos       TodoItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Label {
  id        String      @id @default(cuid())
  name      String
  color     String
  taskLinks TaskLabel[]
}

model Task {
  id             String           @id @default(cuid())
  boardId        String
  title          String
  description    String
  status         String
  priority       String
  assignee       String
  startDate      DateTime
  dueDate        DateTime
  estimateHours  Int
  tags           String
  board          Board            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  checklist      TodoItem[]
  labels         TaskLabel[]
  dependencies   TaskDependency[] @relation("TaskDependencies")
  dependents      TaskDependency[] @relation("TaskDependents")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model TaskDependency {
  taskId       String
  dependencyId String
  task         Task   @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dependency   Task   @relation("TaskDependents", fields: [dependencyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([taskId, dependencyId])
}

model TodoItem {
  id        String   @id @default(cuid())
  workspaceId String
  taskId    String?
  title     String
  done      Boolean  @default(false)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime @default(now())
}
